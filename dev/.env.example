# ============================================================================
# Dev environment reference values.
#
# NOTE: the dev stack is currently self-contained — the values below are NOT yet
# read by dev/docker-compose.yml or dev/init.sh (they are hard-coded there for
# simplicity). This file documents what those values are. They are mirrored in
# the compose file and init.sh, so keep them in sync if you change either.
#
# To actually parameterize dev later, switch compose/init.sh to ${VAR:-default}.
# ============================================================================

# Site
SITE_NAME=development.localhost
ADMIN_PASSWORD=admin

# MariaDB (root)
DB_ROOT_PASSWORD=123

# Python for the bench (frappe v16.23+ requires Python >= 3.14)
PY_VERSION=3.14.2

# Versions tracked by the submodules
FRAPPE_VERSION=version-16
ERPNEXT_VERSION=version-16

# Ports exposed by the frappe container (web / socketio / live-reload)
WEB_PORT=8000
