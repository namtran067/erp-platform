# ============================================================================
# Production environment. Copy to prod/.env and adjust:
#   cp prod/.env.example prod/.env
#
# Then bring up the stack:
#   make prod-up
# ============================================================================

# ---- Image -------------------------------------------------------------------
# The custom image produced by `make build-prod` (scripts/build-prod.sh).
CUSTOM_IMAGE=my-erpnext
CUSTOM_TAG=v16-custom
# Version line (used only as a fallback tag when CUSTOM_IMAGE/TAG are unset).
ERPNEXT_VERSION=v16
PULL_POLICY=missing
RESTART_POLICY=unless-stopped

# ---- Site --------------------------------------------------------------------
# Your production hostname / default site. Also drives the nginx site header.
FRAPPE_SITE_NAME_HEADER=erp.example.com
SITE_NAME=erp.southsun.io.vn
# Admin password — used ONLY when creating the first site (make prod-new-site).
ADMIN_PASSWORD=change_me_admin
# MariaDB root password — reused as MYSQL_ROOT_PASSWORD for the db service and
# as --db-root-password for site creation.
DB_PASSWORD=change_me_db_root

# ---- Gunicorn (backend) ------------------------------------------------------
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ---- Frontend (nginx) behind a reverse proxy --------------------------------
# If you run behind your own proxy (Traefik / nginx), keep these defaults.
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m
